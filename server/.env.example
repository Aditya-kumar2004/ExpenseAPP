# Server Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection (pooler URL, port 6543 for Prisma)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="replace-with-a-long-random-string-for-access-tokens"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string-for-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── Currency API ─────────────────────────────────────────────────────────────
# Free key from https://openexchangerates.org
OER_APP_ID="your-open-exchange-rates-app-id"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"
